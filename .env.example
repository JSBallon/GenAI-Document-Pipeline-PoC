# OpenRouter.ai API Configuration
# Sign up at: https://openrouter.ai/
# Allows flexible model switching between GPT-4, Claude Sonnet, and other models
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model Selection (can be changed without API switch)
# Options: 
#   - openai/gpt-4-turbo
#   - anthropic/claude-3.5-sonnet
#   - anthropic/claude-3-opus
#   - openai/gpt-4-0125-preview
DEFAULT_MODEL=openai/gpt-4-turbo

# OpenRouter API Base URL
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Optional: Site URL and App Name for OpenRouter analytics
OPENROUTER_SITE_URL=https://github.com/your-org/cv-governance-agent
OPENROUTER_APP_NAME=CV-Governance-Agent

# Logging Configuration
LOG_LEVEL=INFO

# LLM Client Configuration (Optional)
# Request timeout in seconds
LLM_TIMEOUT=60

# Maximum retry attempts for failed API requests
LLM_MAX_RETRIES=3
